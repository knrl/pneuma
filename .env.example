# ╔══════════════════════════════════════════════════════════════╗
# ║  Pneuma Environment Configuration                          ║
# ║  Copy to .env and fill in values.                           ║
# ║  All settings below are optional — sensible defaults apply. ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Slack Integration (optional) ─────────────────────────────────
# Enables: check_recent_chat, ask_team, ingest_slack_channel, escalate_to_human
# Leave blank to disable — no error if unset.
SLACK_BOT_TOKEN=                         # xoxb-... from OAuth & Permissions
SLACK_USER_TOKEN=                        # xoxp-... for check_recent_chat (search:read scope)
SLACK_SIGNING_SECRET=                    # From Basic Information → App Credentials
SLACK_APP_TOKEN=                         # xapp-... from Socket Mode settings
ALLOWED_CHANNELS=                        # Comma-separated channel IDs (e.g. C01ABC,C02DEF)
SLACK_DEFAULT_CHANNEL=                   # Channel ID for ask_team (e.g. C01ABC)
ESCALATION_CHANNEL=                      # Channel ID for escalate_to_human

# ── Microsoft Teams Integration (optional) ───────────────────────
# Enables: check_recent_teams_chat, ask_teams_channel,
#          ingest_teams_channel, escalate_to_teams
# Requires an Azure AD app registration with admin-consented permissions.
# See docs/teams-setup.md for step-by-step instructions.
# Leave blank to disable — no error if unset.
TEAMS_CLIENT_ID=                         # Azure AD app (client) ID
TEAMS_CLIENT_SECRET=                     # Azure AD app client secret
TEAMS_TENANT_ID=                         # Azure AD tenant (directory) ID
TEAMS_TEAM_ID=                           # Default team ID (from Teams admin or channel URL)
TEAMS_ALLOWED_CHANNEL_IDS=               # Comma-separated channel IDs to allow ingestion
TEAMS_DEFAULT_WEBHOOK_URL=               # Incoming webhook URL for ask_teams_channel
TEAMS_ESCALATION_WEBHOOK_URL=            # Incoming webhook URL for escalate_to_teams

# ── Tuning (optional — sensible defaults if unset) ───────────────
# REFACTOR_SIMILARITY_THRESHOLD=0.92     # Dedup cosine similarity (default: 0.92)
# REFACTOR_STALE_DAYS=90                 # Days before archiving (default: 90)
# CONFIDENCE_THRESHOLD=0.65              # Below this → suggest escalation (default: 0.65)
